# --- Supabase (required for production persistence; optional in dev — falls back to in-memory) ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Frontend (exposed to the browser via VITE_ prefix) ---
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: override API base URL (defaults to /api)
# VITE_API_BASE=https://your-domain.com/api

# --- Security API Keys (optional — scan works with mock data if missing) ---
GROQ_API_KEY=your_groq_api_key
VIRUSTOTAL_API_KEY=your_virustotal_api_key
SHODAN_API_KEY=your_shodan_api_key
